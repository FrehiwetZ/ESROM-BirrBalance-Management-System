model monthly_allocations {
  id                                            Int                    @id @default(autoincrement())
  user_id                                       Int
  allocation_month                              DateTime               @db.Date
  amount                                        Decimal                @db.Decimal(10, 2)
  allocated_by                                  Int?
  created_at                                    DateTime?              @default(now()) @db.Timestamp(6)
  updated_at                                    DateTime?              @default(now()) @db.Timestamp(6)
  balance_transactions                          balance_transactions[]
  users_monthly_allocations_allocated_byTousers users?                 @relation("monthly_allocations_allocated_byTousers", fields: [allocated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_monthly_allocations_user_idTousers      users                  @relation("monthly_allocations_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, allocation_month], map: "unique_user_month")
  @@index([user_id], map: "idx_allocations_user")
  @@index([allocation_month], map: "idx_allocations_month")
  @@index([allocated_by, created_at], map: "idx_allocations_allocated_by_created_at")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
