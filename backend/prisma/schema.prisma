/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                                                          Int                     @id @default(autoincrement())
  employee_external_id                                        String?                 @unique @db.VarChar(50)
  fullname                                                    String                  @db.VarChar(150)
  email                                                       String?                 @unique @db.VarChar(150)
  phone_number                                                String                  @unique @db.VarChar(20)
  password_hash                                               String
  department_id                                               Int?
  is_active                                                   Boolean?                @default(true)
  created_at                                                  DateTime?               @default(now()) @db.Timestamp(6)
  updated_at                                                  DateTime?               @default(now()) @db.Timestamp(6)
  audit_logs                                                  audit_logs[]
  balance_transactions                                        balance_transactions[]
  cafe_staff                                                  cafe_staff?
  employee_qr_codes                                           employee_qr_codes?
  feedback                                                    feedback[]
  login_history                                               login_history[]
  monthly_allocations_monthly_allocations_allocated_byTousers monthly_allocations[]   @relation("monthly_allocations_allocated_byTousers")
  monthly_allocations_monthly_allocations_user_idTousers      monthly_allocations[]   @relation("monthly_allocations_user_idTousers")
  notifications                                               notifications[]
  orders_orders_employee_idTousers                            orders[]                @relation("orders_employee_idTousers")
  orders_orders_waiter_idTousers                              orders[]                @relation("orders_waiter_idTousers")
  password_reset_tokens                                       password_reset_tokens[]
  refresh_tokens                                              refresh_tokens[]
  qr_sessions_qr_sessions_employee_idTousers                  qr_sessions[]          @relation("qr_sessions_employee_idTousers")
  qr_sessions_qr_sessions_waiter_idTousers                    qr_sessions[]          @relation("qr_sessions_waiter_idTousers")
  user_roles                                                  user_roles[]
  departments                                                 departments?            @relation(fields: [department_id], references: [id], onUpdate: NoAction)

  @@index([department_id], map: "idx_users_department")
  @@index([is_active], map: "idx_users_active")
}

enum order_method {
  online
  offline_qr
}

enum order_status {
  pending
  confirmed
  preparing
  ready
  completed
  cancelled
  refunded
}

enum transaction_type {
  allocation
  order
  refund
  adjustment
  expiration
}

enum transaction_direction {
  credit
  debit
}

enum notification_type {
  low_balance
  allocation
  order_confirmed
  order_status
  refund
  feedback
  password_reset
}

enum role_name {
  employee
  waiter
  cafe_manager
  company_manager
}
