/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model orders {
  id                              Int           @id @default(autoincrement())
  order_uuid                      String?       @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id                     Int
  cafe_id                         Int
  waiter_id                       Int?
  total_amount                    Decimal       @db.Decimal(10, 2)
  status                          order_status? @default(pending)
  order_method                    order_method
  completed_at                    DateTime?     @db.Timestamp(6)
  created_at                      DateTime?     @default(now()) @db.Timestamp(6)
  order_items                     order_items[]
  cafes                           cafes         @relation(fields: [cafe_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_orders_employee_idTousers users         @relation("orders_employee_idTousers", fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_orders_waiter_idTousers   users?        @relation("orders_waiter_idTousers", fields: [waiter_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([cafe_id], map: "idx_orders_cafe")
  @@index([cafe_id, status, created_at], map: "idx_orders_cafe_status_created_at")
  @@index([created_at], map: "idx_orders_created")
  @@index([created_at, status], map: "idx_orders_created_at_status")
  @@index([employee_id], map: "idx_orders_employee")
  @@index([employee_id, status, created_at], map: "idx_orders_employee_status_created_at")
  @@index([status], map: "idx_orders_status")
  @@index([waiter_id, created_at], map: "idx_orders_waiter_created_at")
}

