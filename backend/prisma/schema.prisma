  is_read    Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_notifications_user")
  @@index([user_id, is_read], map: "idx_notifications_user_read")
  @@index([user_id, is_read, created_at], map: "idx_notifications_user_read_created_at")
}

model qr_sessions {
  id             Int       @id @default(autoincrement())
  session_hash   String    @unique @db.VarChar(64)
  employee_id    Int
  waiter_id      Int
  cafe_id        Int
  expires_at     DateTime  @db.Timestamp(6)
  used_at        DateTime? @db.Timestamp(6)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  cafes          cafes     @relation(fields: [cafe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employee       users     @relation("qr_sessions_employee_idTousers", fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  waiter         users     @relation("qr_sessions_waiter_idTousers", fields: [waiter_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([employee_id, expires_at], map: "idx_qr_sessions_employee_expires")
  @@index([waiter_id, expires_at], map: "idx_qr_sessions_waiter_expires")
  @@index([used_at, expires_at], map: "idx_qr_sessions_used_expires")
}

