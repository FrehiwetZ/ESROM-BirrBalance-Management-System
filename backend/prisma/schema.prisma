generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_logs {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  action      String    @db.VarChar(100)
  entity_type String?   @db.VarChar(100)
  entity_id   Int?
  description String?
  ip_address  String?   @db.VarChar(45)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id, created_at], map: "idx_audit_logs_user_created_at")
  @@index([entity_type, entity_id], map: "idx_audit_logs_entity")
  @@index([created_at], map: "idx_audit_logs_created")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model balance_transactions {
  id                  Int                  @id @default(autoincrement())
  user_id             Int
  allocation_id       Int?
  amount              Decimal              @db.Decimal(10, 2)
  direction           transaction_direction @default(credit)
  transaction_type    transaction_type
  reference_note      String?
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  monthly_allocations monthly_allocations? @relation(fields: [allocation_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id], map: "idx_transactions_user")
  @@index([user_id, created_at], map: "idx_balance_transactions_user_created_at")
  @@index([user_id, direction, created_at], map: "idx_balance_transactions_user_direction_created_at")
  @@index([allocation_id], map: "idx_transactions_allocation")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cafe_staff {
  user_id     Int       @id
  cafe_id     Int
  assigned_at DateTime? @default(now()) @db.Timestamp(6)
  cafes       cafes     @relation(fields: [cafe_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([cafe_id], map: "idx_cafe_staff_cafe")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cafes {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(150)
  location   String?      @db.VarChar(255)
  is_active  Boolean?     @default(true)
  created_at DateTime?    @default(now()) @db.Timestamp(6)
  cafe_staff cafe_staff[]
  feedback   feedback[]
  menu_items menu_items[]
  orders     orders[]
  qr_sessions qr_sessions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model departments {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(100)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users[]
}

