{
  "info": {
    "name": "ESROM BirrBalance API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "orderId", "value": "1" },
    { "key": "qrSessionId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        },
        {
          "name": "Readiness",
          "request": { "method": "GET", "url": "{{baseUrl}}/health/ready" }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_external_id\": \"EMP001\",\n  \"password\": \"Password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Confirm Password Reset",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_external_id\": \"EMP001\",\n  \"otp_code\": \"123456\",\n  \"new_password\": \"Password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/password-reset/confirm"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"preparing\"\n}" },
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/orders/{{orderId}}/cancel"
          }
        },
        {
          "name": "Refund Order",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/orders/{{orderId}}/refund"
          }
        }
      ]
    },
    {
      "name": "Waiter QR",
      "item": [
        {
          "name": "Scan QR",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"qr_token\": \"\"\n}" },
            "url": "{{baseUrl}}/api/waiter/scan"
          }
        },
        {
          "name": "Create Offline Order",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": 1,\n  \"cafe_id\": 1,\n  \"qr_session_id\": \"{{qrSessionId}}\",\n  \"password\": \"Password123\",\n  \"items\": [\n    { \"menu_item_id\": 1, \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/waiter/order"
          }
        }
      ]
    },
    {
      "name": "Employee",
      "item": [
        {
          "name": "Orders Paginated",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/employee/orders?page=1&limit=20&sort=-created_at"
          }
        },
        {
          "name": "Notifications Paginated",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/employee/notifications?page=1&limit=20&sort=-created_at"
          }
        },
        {
          "name": "Submit Feedback",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Great service\",\n  \"cafe_id\": 1\n}" },
            "url": "{{baseUrl}}/api/employee/feedback"
          }
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "url": "{{baseUrl}}/api/audit-logs?page=1&limit=20&action=order"
          }
        }
      ]
    }
  ]
}
